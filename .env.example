# ================================================
# RENDER.COM UCHUN MUHIT O'ZGARUVCHILARI
# Bu faylni .env deb nusxalamang! 
# Barcha qiymatlarni Render Dashboard > Environment ga kiriting
# ================================================

# Server
NODE_ENV=production
PORT=10000

# MongoDB Atlas (majburiy)
# mongodb+srv://username:password@cluster.mongodb.net/cashflow_game
MONGODB_URI=

# JWT (majburiy - kamida 32 ta tasodifiy belgi)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# O'yin sozlamalari (ixtiyoriy)
MAX_PLAYERS_PER_ROOM=6
MIN_PLAYERS_TO_START=2
STARTING_BALANCE=3000

# Logging (ixtiyoriy)
LOG_LEVEL=info
# LOG_DIR ni RENDER DA KIRITMASLIK KERAK (ephemeral filesystem)
